---
import { getSessionFromCookie } from "@auth/session";
import BaseLayout from "../layouts/BaseLayout.astro";

const session = await getSessionFromCookie(Astro.cookies, Astro.locals.db);

if (!session) {
  return Astro.redirect("/login");
}
---

<BaseLayout
  title="Home"
  description="Homepage"
  includeSidebar={true}
  prefetchUrls={["/explore", "/reviews"]}
  session={session}
  user={session.user}
>
  <h1 class="text-4xl font-bold">Feed</h1>
  <p class="mt-2 opacity-70">Recent reviews and activity from people you follow.</p>
</BaseLayout>