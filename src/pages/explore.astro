---
import { getSessionFromCookie } from "@auth/session";
import BaseLayout from "@layouts/BaseLayout.astro";

const session = await getSessionFromCookie(Astro.cookies);
if (!session) {
  return Astro.redirect("/login");
}
---

<BaseLayout
  title="Explore"
  description="Browse and search kebab spots"
  includeSidebar={true}
  prefetchUrls={["/", "/reviews"]}
  theme={session.theme}
  username={session.user.username}
  isAdmin={session.user.isAdmin}
>
  <h1 class="text-4xl font-bold">Explore</h1>
  <p class="mt-2 opacity-70">Browse, search, and find kebab spots near you.</p>
</BaseLayout>